{
  "expo": {
    "name": "Proof.",
    "slug": "proof-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "proof",
    "splash": {
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.proof.app",
      "config": {
        "googleMapsApiKey": "AIzaSyDW8Yq6u3_IaOWTnUyy_SLlW96pkmPaWoA"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.proof.app",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDW8Yq6u3_IaOWTnUyy_SLlW96pkmPaWoA"
        }
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      "expo-notifications",
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Proof. needs your location to guide you through plans.",
          "locationWhenInUsePermission": "Proof. needs your location to guide you through plans."
        }
      ]
    ]
  }
}
